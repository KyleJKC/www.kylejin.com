---
import HeaderLink from "./HeaderLink.astro";
import DarkModeToggle from "./DarkModeToggle.astro";
---

<header>
  <a
    class="unset absolute z-10 left-[50%] -top-[100rem] translate-x-[-50%] bg-white text-black px-8 py-2 focus:top-[initial]"
    href="#main"
  >
    Skip to content
  </a>
  <nav>
    <section class="text-text-bold">
      <ul class="unset flex gap-4 [&>li]:p-0">
        <li><HeaderLink href="/">Home</HeaderLink></li>
        <li><HeaderLink href="/blog">Blog</HeaderLink></li>
        <li><HeaderLink href="/projects">Projects</HeaderLink></li>
      </ul>
    </section>
  </nav>
  <div
    class="max-[375px]:hidden justify-self-end py-2 flex items-center content-center text-text-bold"
  >
    <!-- GitHub -->
    <a
      class="unset text-xl ml-4 hover:text-text-link"
      href="https://github.com/KyleJKC/"
    >
      <i class="fa-brands fa-github" aria-hidden="true" title="My GitHub"></i>
      <span class="fa-sr-only">GitHub</span>
    </a>
    <!-- Instagram -->
    <a
      class="unset text-xl ml-4 hover:text-text-link"
      href="https://www.instagram.com/kylejinkc/"
    >
      <i class="fa-brands fa-instagram" aria-hidden="true" title="My Instagram"
      ></i>
      <span class="fa-sr-only">Instagram</span>
    </a>
    <!-- Instagram -->
    <a
      class="unset text-xl ml-4 hover:text-text-link"
      href="https://chat.kylejin.com/"
    >
      <i class="fa-solid fa-robot" aria-hidden="true" title="ChatJIN"></i>
      <span class="fa-sr-only">ChatJin</span>
    </a>
    <!-- Snapchat -->
    <!-- <a
      class="unset text-xl ml-4 hover:text-text-link"
      href="https://t.snapchat.com/98XzWdbs/"
    >
      <i class="fa-brands fa-snapchat" aria-hidden="true" title="My Snapchat"
      ></i>
      <span class="fa-sr-only">Snapchat</span>
    </a> -->
    <!-- Bilibili -->
    <!-- <a
      class="unset text-xl ml-4 hover:text-text-link"
      href="https://space.bilibili.com/354096445"
    >
      <i class="fa-brands fa-bilibili" aria-hidden="true" title="My Bilibili"
      ></i>
      <span class="fa-sr-only">Bilibili</span>
    </a> -->
  </div>
  <DarkModeToggle />
</header>
<style>
  header {
    grid-area: header;
    display: grid;
    align-items: center;
    grid-template-columns: minmax(0, 1fr) minmax(0, max-content) minmax(
        0,
        max-content
      );
  }
</style>
